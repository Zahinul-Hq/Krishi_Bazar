@{
    ViewData["Title"] = "Register";
}

<head>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/Auth/RegisterPageStyles.css" />
</head>


<div class="container mt-5">
    <h2>Register</h2>
    <form method="post">
        <div class="mb-3">
            <label>Full Name</label>
            <input type="text" name="FullName" class="form-control" required>
        </div>
        <div class="mb-3">
            <label>Email</label>
            <input type="email" name="Email" class="form-control" required>
        </div>
        <div class="mb-3">
            <label>Password</label>
            <input type="password" name="Password" class="form-control" required>
        </div>
        <div class="mb-3">
            <label>Phone Number</label>
            <input type="text" name="PhoneNumber" class="form-control">
        </div>
        <div class="mb-3">
            <label>Are you a farmer?</label>
            <select name="IsFarmer" class="form-control">
                <option value="true">Yes</option>
                <option value="false">No</option>
            </select>
        </div>
        <div class="mb-3">
            <label>Postal Code</label>
            <select name="postalCode" id="postalCode" class="form-control" required>
                <option value="">Select a Postal Code</option>
                @if (ViewBag.Locations != null)
                {
                    @foreach (var loc in ViewBag.Locations)
                    {
                        <option value="@loc.PostalCode">@loc.PostalCode</option>
                    }
                }
                else
                {
                    <option value="">No locations available</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label>District</label>
            <input type="text" id="district" class="form-control" readonly>
        </div>
        <div class="mb-3">
            <label>Upazila</label>
            <input type="text" id="upazila" class="form-control" readonly>
        </div>
        <div class="mb-3">
            <label>Thana</label>
            <input type="text" id="thana" class="form-control" readonly>
        </div>
        <button type="submit" class="btn btn-primary">Register</button>
    </form>
</div>

<script>
    document.getElementById("postalCode").addEventListener("change", function() {
        let selectedOption = this.options[this.selectedIndex];
        document.getElementById("district").value = selectedOption.getAttribute("data-district");
        document.getElementById("upazila").value = selectedOption.getAttribute("data-upazila");
        document.getElementById("thana").value = selectedOption.getAttribute("data-thana");
    });
</script>
