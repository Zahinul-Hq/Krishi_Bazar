@model List<dynamic>
@{
    ViewData["Title"] = "My Cart";
}
<head>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/BuyerDashboard/Cart.css" />
</head>

<div class="main-container">
    <nav class="sidebar">
        <h3 class="sidebar-title">Dashboard</h3>
        <ul class="sidebar-menu">
            <li><a href="@Url.Action("Index", "BuyerDashboard")">Home</a></li>
            <li><a href="@Url.Action("TrackOrders", "BuyerDashboard")">Track My Orders</a></li>
            <li><a href="@Url.Action("DeliveredOrders", "BuyerDashboard")">Delivered Orders</a></li>
            <li><a href="#">Profile</a></li>
            <li><a href="@Url.Action("Cart", "BuyerDashboard")">Cart</a></li>
            <li>
                <form asp-action="Logout" asp-controller="Auth" method="post" style="display: inline;">
                    <button type="submit" class="logout-button">Logout</button>
                </form>
            </li>
        </ul>
    </nav>

    <div class="main-content">
        <h2 class="cart-title">My Cart</h2>

        

            @if (Model.Count == 0)
            {
                <div class="alert alert-info">Your cart is empty.</div>
            }
            else
            {
                <div class="row">
                    @foreach (var order in Model)
                    {
                        <div class="col-md-4 mb-4">
                            <div class="card cart-item">
                                <img src="@order.Product.Photos" class="card-img-top cart-item-image" alt="Product Image">
                                <div class="card-body">
                                    <h5 class="card-title cart-item-title">@order.Product.Name</h5>
                                    <p class="card-text">Quantity: @order.QuantityToBuy</p>
                                    <p class="card-text">Total Price: @order.TotalPrice</p>

                                    <form method="get" asp-action="Payment" asp-controller="BuyerDashboard">
                                        <input type="hidden" name="orderId" value="@order.OrderID" />
                                        <button type="submit" class="btn btn-success pay-btn">Pay Now</button>
                                    </form>
                                    <form method="post" asp-action="RemoveFromCart" asp-controller="BuyerDashboard" class="mt-2">
                                        <input type="hidden" name="orderId" value="@order.OrderID" />
                                        <button type="submit" class="btn btn-danger remove-btn">Remove from Cart</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        
    </div>
    
</div>
