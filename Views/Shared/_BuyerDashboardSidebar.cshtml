<!-- Views/Shared/_BuyerDashboardLayout.cshtml -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - KrishiBazaar</title>
    <link rel="stylesheet" href="~/css/BuyerDashboard/Index.css" />
    <link rel="stylesheet" href="~/css/BuyerDashboard/ProductDetailsStyles.css" />
    <link rel="stylesheet" href="~/css/StyleSheet.css" />
    @* Add additional CSS files if necessary *@
</head>
<body>
    <!-- Main Container -->
    <div class="main-container">
        <!-- Sidebar -->
        <nav class="sidebar">
            <h3 class="sidebar-title">Dashboard</h3>
            <ul class="sidebar-menu">
                <li><a href="@Url.Action("Index", "BuyerDashboard")">Home</a></li>
                <li><a href="@Url.Action("TrackOrders", "BuyerDashboard")">Track My Orders</a></li>
                <li><a href="@Url.Action("DeliveredOrders", "BuyerDashboard")">Delivered Orders</a></li>
                <li><a href="#">Profile</a></li>
                <li><a href="@Url.Action("Cart", "BuyerDashboard")">Cart</a></li>
            </ul>
        </nav>

        <!-- Content Area -->
        <div class="content-area">
            @RenderBody()  <!-- This is where the content of each page will go -->
        </div>
    </div>
</body>
</html>
